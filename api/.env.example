# API Environment Variables
# Copy this to .env and fill in your values

# Required: Database (use MongoDB Atlas free tier)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/todoapp?retryWrites=true&w=majority

# Required: JWT & Security  
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-long-change-this-in-production
ADMIN_EMAIL=your-admin@example.com

# Required for Google OAuth (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: Custom URLs (defaults work for local dev)
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:5000

# SMTP for emails (optional - use service like Resend/Brevo)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=your-resend-key@resend.com  
SMTP_PASS=your-resend-key
SMTP_FROM=noreply@yourapp.com

# Production only
NODE_ENV=production

# Uncomment for deployments
# RENDER_URL=https://your-app.onrender.com  
# VERCEL_URL=https://your-app.vercel.app

